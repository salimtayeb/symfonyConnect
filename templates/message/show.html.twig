{% extends 'base.html.twig' %}

{% block title %}Conversation avec {{ otherUser.username }}{% endblock %}

{% block body %}
    <section style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem 4rem 1rem;">
        <div style="margin-bottom: 1.5rem;">
            <p style="margin: 0 0 0.7rem 0;">
                <a
                    href="{{ path('app_messages') }}"
                    style="
                        color: #4c6ef5;
                        text-decoration: none;
                        font-weight: 700;
                        font-size: 1.05rem;
                    "
                >
                    ← Retour aux conversations
                </a>
            </p>

            <h1 style="
                font-size: 3rem;
                font-weight: 800;
                color: #1f2a44;
                margin: 0;
            ">
                Conversation avec {{ otherUser.username }}
            </h1>
        </div>

        <div style="
            background: #ffffff;
            border: 1px solid #dbe3f0;
            border-radius: 30px;
            box-shadow: 0 12px 30px rgba(76, 110, 245, 0.08);
            overflow: hidden;
        ">
            <div style="
                padding: 1.2rem 1.5rem;
                border-bottom: 1px solid #e9eef8;
                background: linear-gradient(180deg, #fbfcff 0%, #f4f7ff 100%);
                display: flex;
                align-items: center;
                gap: 0.9rem;
            ">
                <div style="
                    width: 52px;
                    height: 52px;
                    border-radius: 50%;
                    background: linear-gradient(135deg, #4c6ef5 0%, #7c97ff 100%);
                    color: white;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-weight: 800;
                    font-size: 1.1rem;
                    flex-shrink: 0;
                ">
                    {{ otherUser.username|slice(0, 1)|upper }}
                </div>

                <div>
                    <p style="
                        margin: 0 0 0.15rem 0;
                        font-size: 1.12rem;
                        font-weight: 700;
                        color: #1f2a44;
                    ">
                        {{ otherUser.username }}
                    </p>

                    <p style="
                        margin: 0;
                        font-size: 0.95rem;
                        color: #667085;
                    ">
                        Conversation privée
                    </p>
                </div>
            </div>

            <div
                data-messages
                style="
                    padding: 1.5rem;
                    background: #f8faff;
                    min-height: 360px;
                    max-height: 520px;
                    overflow-y: auto;
                    display: flex;
                    flex-direction: column;
                    gap: 1rem;
                "
            >
                {% if messages is empty %}
                    <div style="
                        background: #ffffff;
                        border: 1px dashed #c7d5ff;
                        border-radius: 22px;
                        padding: 2rem;
                        text-align: center;
                    ">
                        <p style="
                            margin: 0 0 0.6rem 0;
                            font-size: 1.15rem;
                            font-weight: 700;
                            color: #1f2a44;
                        ">
                            Aucun message pour le moment
                        </p>

                        <p style="
                            margin: 0;
                            color: #667085;
                            font-size: 1rem;
                        ">
                            Envoie le premier message pour démarrer la conversation.
                        </p>
                    </div>
                {% else %}
                    {% for message in messages %}
                        {% set isMine = message.sender.id == app.user.id %}

                        <div style="
                            display: flex;
                            justify-content: {{ isMine ? 'flex-end' : 'flex-start' }};
                        ">
                            <div style="
                                max-width: 72%;
                                padding: 1rem 1.1rem;
                                border-radius: 20px;
                                background: {{ isMine ? 'linear-gradient(135deg, #4c6ef5 0%, #6f8cff 100%)' : '#ffffff' }};
                                color: {{ isMine ? '#ffffff' : '#1f2a44' }};
                                border: {{ isMine ? 'none' : '1px solid #e4e7ec' }};
                                box-shadow: 0 8px 20px rgba(76, 110, 245, 0.08);
                            ">
                                <p style="
                                    margin: 0 0 0.4rem 0;
                                    font-size: 0.9rem;
                                    font-weight: 700;
                                    opacity: 0.9;
                                ">
                                    {{ isMine ? 'Moi' : message.sender.username }}
                                </p>

                                {% if message.content %}
                                    <p style="
                                        margin: 0 0 0.55rem 0;
                                        font-size: 1rem;
                                        line-height: 1.5;
                                        white-space: pre-wrap;
                                    ">
                                        {{ message.content }}
                                    </p>
                                {% endif %}

                                {% if message.image %}
                                    <img
                                        src="{{ asset('uploads/messages/' ~ message.image) }}"
                                        alt="Image envoyée"
                                        style="
                                            max-width: 220px;
                                            width: 100%;
                                            border-radius: 12px;
                                            margin-bottom: 0.55rem;
                                            display: block;
                                            box-shadow: 0 6px 14px rgba(0,0,0,0.10);
                                        "
                                    >
                                {% endif %}

                                <p style="
                                    margin: 0;
                                    font-size: 0.8rem;
                                    opacity: 0.8;
                                    text-align: right;
                                ">
                                    {{ message.createdAt|date('d/m/Y H:i') }}
                                </p>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>

            <div style="
                padding: 1.25rem 1.5rem 1.5rem 1.5rem;
                border-top: 1px solid #e9eef8;
                background: #ffffff;
            ">
                <form method="post" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 0.9rem;">
                    <label for="content" style="
                        font-size: 1rem;
                        font-weight: 700;
                        color: #1f2a44;
                    ">
                        Nouveau message
                    </label>

                    <textarea
                        id="content"
                        name="content"
                        rows="4"
                        placeholder="Écris ton message ici... 😀"
                        style="
                            width: 100%;
                            box-sizing: border-box;
                            border: 1px solid #d1d5db;
                            border-radius: 16px;
                            padding: 1rem;
                            font-size: 1rem;
                            resize: vertical;
                            background: #f9fafb;
                            outline: none;
                        "
                    ></textarea>

                    <input
                        type="file"
                        name="image"
                        accept="image/*"
                        style="
                            font-size: 0.95rem;
                            color: #374151;
                        "
                    >

                    <div id="image-preview" style="display: none;">
                        <p style="
                            font-size: 0.9rem;
                            margin: 0 0 0.5rem 0;
                            color: #374151;
                            font-weight: 600;
                        ">
                            Aperçu :
                        </p>
                        <img
                            id="preview-img"
                            alt="Aperçu de l'image"
                            style="
                                max-width: 200px;
                                border-radius: 10px;
                                display: block;
                                box-shadow: 0 6px 14px rgba(0,0,0,0.10);
                            "
                        >
                    </div>

                    <div style="display: flex; justify-content: flex-end;">
                        <button
                            type="submit"
                            style="
                                border: none;
                                background: linear-gradient(135deg, #4c6ef5 0%, #6f8cff 100%);
                                color: white;
                                padding: 0.9rem 1.4rem;
                                border-radius: 14px;
                                font-size: 0.98rem;
                                font-weight: 700;
                                cursor: pointer;
                                box-shadow: 0 8px 18px rgba(76, 110, 245, 0.22);
                            "
                        >
                            Envoyer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const container = document.querySelector('[data-messages]');
            const textarea = document.getElementById('content');
            const inputFile = document.querySelector('input[name="image"]');
            const previewContainer = document.getElementById('image-preview');
            const previewImg = document.getElementById('preview-img');

            if (container) {
                container.scrollTop = container.scrollHeight;
            }

            if (textarea) {
                textarea.focus();
            }

            if (inputFile) {
                inputFile.addEventListener('change', function () {
                    const file = this.files[0];

                    if (file) {
                        const reader = new FileReader();

                        reader.onload = function (e) {
                            previewImg.src = e.target.result;
                            previewContainer.style.display = 'block';
                        };

                        reader.readAsDataURL(file);
                    } else {
                        previewImg.src = '';
                        previewContainer.style.display = 'none';
                    }
                });
            }
        });
    </script>
{% endblock %}