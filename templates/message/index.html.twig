{% extends 'base.html.twig' %}

{% block title %}Messagerie{% endblock %}

{% block body %}
    <section style="max-width: 1100px; margin: 0 auto; padding: 2rem 1rem 4rem 1rem;">
        <div style="margin-bottom: 2rem;">
            <h1 style="
                font-size: 3.2rem;
                font-weight: 800;
                color: #1f2a44;
                margin-bottom: 0.75rem;
            ">
                Messagerie
            </h1>

            <p style="
                font-size: 1.1rem;
                color: #667085;
                margin: 0;
            ">
                Retrouve ici toutes tes conversations privées.
            </p>
        </div>

        <div style="
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
        ">
            <div style="
                background: #ffffff;
                border: 1px solid #dbe3f0;
                border-radius: 28px;
                padding: 1.75rem;
                box-shadow: 0 12px 30px rgba(76, 110, 245, 0.08);
            ">
                <div style="
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    margin-bottom: 1.5rem;
                    gap: 1rem;
                    flex-wrap: wrap;
                ">
                    <h2 style="
                        margin: 0;
                        font-size: 1.6rem;
                        font-weight: 700;
                        color: #1f2a44;
                    ">
                        Conversations
                    </h2>

                    <span style="
                        display: inline-block;
                        padding: 0.45rem 0.9rem;
                        border-radius: 999px;
                        background: #eef3ff;
                        color: #4c6ef5;
                        font-weight: 700;
                        font-size: 0.95rem;
                    ">
                        {{ conversations|length }} conversation{{ conversations|length > 1 ? 's' : '' }}
                    </span>
                </div>

                {% if conversations is empty %}
                    <div style="
                        background: linear-gradient(135deg, #f8faff 0%, #eef3ff 100%);
                        border: 1px dashed #c7d5ff;
                        border-radius: 22px;
                        padding: 2rem;
                        text-align: center;
                    ">
                        <p style="
                            margin: 0 0 0.6rem 0;
                            font-size: 1.15rem;
                            font-weight: 700;
                            color: #1f2a44;
                        ">
                            Aucune conversation pour le moment
                        </p>

                        <p style="
                            margin: 0;
                            color: #667085;
                            font-size: 1rem;
                        ">
                            Dès que tu échanges avec un utilisateur, la conversation apparaîtra ici.
                        </p>
                    </div>
                {% else %}
                    <div style="
                        display: flex;
                        flex-direction: column;
                        gap: 1rem;
                    ">
                        {% for user in conversations %}
                            <div style="
                                display: flex;
                                align-items: center;
                                justify-content: space-between;
                                gap: 1rem;
                                padding: 1rem 1.2rem;
                                border: 1px solid #e4e7ec;
                                border-radius: 20px;
                                background: #f9fbff;
                            ">
                                <div style="
                                    display: flex;
                                    align-items: center;
                                    gap: 0.9rem;
                                ">
                                    <div style="
                                        width: 52px;
                                        height: 52px;
                                        border-radius: 50%;
                                        background: linear-gradient(135deg, #4c6ef5 0%, #7c97ff 100%);
                                        color: white;
                                        display: flex;
                                        align-items: center;
                                        justify-content: center;
                                        font-weight: 800;
                                        font-size: 1.1rem;
                                        flex-shrink: 0;
                                    ">
                                        {{ user.username|slice(0, 1)|upper }}
                                    </div>

                                    <div>
                                        <p style="
                                            margin: 0 0 0.2rem 0;
                                            font-size: 1.08rem;
                                            font-weight: 700;
                                            color: #1f2a44;
                                        ">
                                            {{ user.username }}
                                        </p>

                                        <p style="
                                            margin: 0;
                                            font-size: 0.95rem;
                                            color: #667085;
                                        ">
                                            Conversation privée
                                        </p>
                                    </div>
                                </div>

                                <a
                                    href="{{ path('app_message_show', {id: user.id}) }}"
                                    style="
                                        display: inline-block;
                                        padding: 0.65rem 1rem;
                                        border-radius: 14px;
                                        background: linear-gradient(135deg, #4c6ef5 0%, #6f8cff 100%);
                                        color: white;
                                        font-weight: 700;
                                        font-size: 0.95rem;
                                        text-decoration: none;
                                        box-shadow: 0 8px 18px rgba(76, 110, 245, 0.22);
                                    "
                                >
                                    Ouvrir
                                </a>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div style="
                background: #ffffff;
                border: 1px solid #dbe3f0;
                border-radius: 28px;
                padding: 1.75rem;
                box-shadow: 0 12px 30px rgba(76, 110, 245, 0.08);
            ">
                <div style="
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    margin-bottom: 1.25rem;
                    gap: 1rem;
                    flex-wrap: wrap;
                ">
                    <h2 style="
                        margin: 0;
                        font-size: 1.45rem;
                        font-weight: 700;
                        color: #1f2a44;
                    ">
                        Envoyer un message
                    </h2>

                    <span style="
                        display: inline-block;
                        padding: 0.45rem 0.9rem;
                        border-radius: 999px;
                        background: #eef3ff;
                        color: #4c6ef5;
                        font-weight: 700;
                        font-size: 0.95rem;
                    ">
                        {{ followedUsers|length }} suivi{{ followedUsers|length > 1 ? 's' : '' }}
                    </span>
                </div>

                {% if followedUsers is empty %}
                    <div style="
                        background: #f8fafc;
                        border: 1px dashed #c7d5ff;
                        border-radius: 20px;
                        padding: 1.5rem;
                        text-align: center;
                    ">
                        <p style="
                            margin: 0 0 0.5rem 0;
                            font-size: 1.05rem;
                            font-weight: 700;
                            color: #1f2a44;
                        ">
                            Tu ne suis encore personne
                        </p>

                        <p style="
                            margin: 0;
                            color: #667085;
                            font-size: 0.96rem;
                        ">
                            Suis des utilisateurs pour pouvoir leur écrire rapidement.
                        </p>
                    </div>
                {% else %}
                    <div style="
                        display: flex;
                        flex-direction: column;
                        gap: 0.9rem;
                    ">
                        {% for followedUser in followedUsers %}
                            <div style="
                                display: flex;
                                align-items: center;
                                justify-content: space-between;
                                gap: 1rem;
                                padding: 1rem 1.1rem;
                                border: 1px solid #e4e7ec;
                                border-radius: 18px;
                                background: #f9fbff;
                            ">
                                <div style="
                                    display: flex;
                                    align-items: center;
                                    gap: 0.9rem;
                                ">
                                    <div style="
                                        width: 46px;
                                        height: 46px;
                                        border-radius: 50%;
                                        background: linear-gradient(135deg, #60a5fa, #2563eb);
                                        color: white;
                                        display: flex;
                                        align-items: center;
                                        justify-content: center;
                                        font-weight: 800;
                                        font-size: 1rem;
                                        flex-shrink: 0;
                                    ">
                                        {{ followedUser.username|slice(0, 1)|upper }}
                                    </div>

                                    <div>
                                        <p style="
                                            margin: 0 0 0.2rem 0;
                                            font-size: 1rem;
                                            font-weight: 700;
                                            color: #1f2a44;
                                        ">
                                            {{ followedUser.username }}
                                        </p>

                                        <p style="
                                            margin: 0;
                                            font-size: 0.92rem;
                                            color: #667085;
                                        ">
                                            Utilisateur suivi
                                        </p>
                                    </div>
                                </div>

                                <a
                                    href="{{ path('app_message_show', {id: followedUser.id}) }}"
                                    style="
                                        display: inline-block;
                                        padding: 0.65rem 1rem;
                                        border-radius: 14px;
                                        background: linear-gradient(135deg, #60a5fa, #2563eb);
                                        color: white;
                                        font-weight: 700;
                                        font-size: 0.95rem;
                                        text-decoration: none;
                                        box-shadow: 0 8px 18px rgba(37, 99, 235, 0.22);
                                    "
                                >
                                    Envoyer
                                </a>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}