{% extends 'base.html.twig' %}

{% block title %}Créer un post{% endblock %}

{% block body %}
<style>
    .post-page {
        max-width: 720px;
        margin: 40px auto;
        padding: 0 16px 40px;
    }

    .post-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 24px;
        color: #1f2937;
    }

    .post-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
    }

    .post-subtitle {
        margin: 0 0 20px;
        color: #6b7280;
        font-size: 15px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #111827;
    }

    .form-control,
    .form-textarea {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        padding: 14px 16px;
        font-size: 15px;
        outline: none;
        box-sizing: border-box;
        background: #f9fafb;
    }

    .form-textarea {
        min-height: 140px;
        resize: vertical;
    }

    .form-control:focus,
    .form-textarea:focus {
        border-color: #60a5fa;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.15);
    }

    .actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 8px;
    }

    .btn-primary {
        border: none;
        background: linear-gradient(135deg, #60a5fa, #2563eb);
        color: white;
        padding: 12px 22px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 6px 16px rgba(37, 99, 235, 0.25);
    }

    .form-errors {
        color: #b91c1c;
        font-size: 14px;
        margin-top: 6px;
    }

    .form-global-errors {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
        border-radius: 12px;
        padding: 12px 14px;
        margin-bottom: 18px;
    }

    .hint {
        font-size: 13px;
        color: #6b7280;
        margin-top: 6px;
    }

    body {
        background: #f3f4f6;
    }
</style>

<div class="post-page">
    <h1 class="post-title">Créer un post</h1>

    <div class="post-card">
        <p class="post-subtitle">
            Partage une idée, une humeur ou un moment avec la communauté.
        </p>

        {{ form_start(form) }}

            {% if not form.vars.valid %}
                <div class="form-global-errors">
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {
                    'attr': {
                        'class': 'form-textarea',
                        'placeholder': 'Exprime-toi...'
                    }
                }) }}
                <div class="form-errors">
                    {{ form_errors(form.description) }}
                </div>
                <div class="hint">Minimum quelques mots pour un post de qualité.</div>
            </div>

            <div class="form-group">
                {{ form_label(form.lieu) }}
                {{ form_widget(form.lieu, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': 'Exemple : Paris, France'
                    }
                }) }}
                <div class="form-errors">
                    {{ form_errors(form.lieu) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.image) }}
                {{ form_widget(form.image, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': 'https://...'
                    }
                }) }}
                <div class="form-errors">
                    {{ form_errors(form.image) }}
                </div>
            </div>

            <div class="actions">
                <button type="submit" class="btn-primary">Publier</button>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}